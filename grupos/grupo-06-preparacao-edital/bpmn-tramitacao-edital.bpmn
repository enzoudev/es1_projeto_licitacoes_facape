<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_G06"
                  targetNamespace="http://grupo06.edital/bpmn">

  <bpmn:collaboration id="Collaboration_G06">
    <bpmn:participant id="Participant_G06" name="Módulo G06 - Sistema (Tramitação Interna)" processRef="Process_G06" />
    <bpmn:participant id="Participant_Prefeitura" name="Prefeitura (Tramitação Externa)" processRef="Process_Prefeitura" />
    <bpmn:messageFlow id="MessageFlow_Envio" name="Edital + Anexos" sourceRef="Task_Enviar" targetRef="Task_ReceberEdital" />
    <bpmn:messageFlow id="MessageFlow_Devolucao" name="Edital devolvido" sourceRef="Task_Devolver" targetRef="Task_Corrigir" />
  </bpmn:collaboration>

  <bpmn:process id="Process_G06" name="Tramitação Interna" isExecutable="false">
    <bpmn:startEvent id="StartEvent_Inicio" name="Início">
      <bpmn:outgoing>SequenceFlow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_Receber" name="Receber TR (G04) e Mapa de Risco (G05)">
      <bpmn:incoming>SequenceFlow_1</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_2</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_Formatar" name="Formatar Edital no padrão oficial">
      <bpmn:incoming>SequenceFlow_2</bpmn:incoming>
      <bpmn:incoming>SequenceFlow_Loop</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_3</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_Anexar" name="Anexar TR e Mapa de Risco ao Edital">
      <bpmn:incoming>SequenceFlow_3</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_4</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_Validar" name="Edital completo?">
      <bpmn:incoming>SequenceFlow_4</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_Completo</bpmn:outgoing>
      <bpmn:outgoing>SequenceFlow_Pendente</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_Corrigir" name="Corrigir pendências apontadas">
      <bpmn:incoming>SequenceFlow_Pendente</bpmn:incoming>
      <bpmn:incoming>MessageFlow_Devolucao</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_Loop</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_Enviar" name="Enviar Edital para a Prefeitura">
      <bpmn:incoming>SequenceFlow_Completo</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_5</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_Registrar" name="Registrar data/hora e status de envio">
      <bpmn:incoming>SequenceFlow_5</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_6</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_Fim" name="Fim da Tramitação Interna">
      <bpmn:incoming>SequenceFlow_6</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="SequenceFlow_1" sourceRef="StartEvent_Inicio" targetRef="Task_Receber" />
    <bpmn:sequenceFlow id="SequenceFlow_2" sourceRef="Task_Receber" targetRef="Task_Formatar" />
    <bpmn:sequenceFlow id="SequenceFlow_3" sourceRef="Task_Formatar" targetRef="Task_Anexar" />
    <bpmn:sequenceFlow id="SequenceFlow_4" sourceRef="Task_Anexar" targetRef="Gateway_Validar" />
    <bpmn:sequenceFlow id="SequenceFlow_Completo" name="Completo" sourceRef="Gateway_Validar" targetRef="Task_Enviar" />
    <bpmn:sequenceFlow id="SequenceFlow_Pendente" name="Pendências encontradas" sourceRef="Gateway_Validar" targetRef="Task_Corrigir" />
    <bpmn:sequenceFlow id="SequenceFlow_Loop" sourceRef="Task_Corrigir" targetRef="Task_Formatar" />
    <bpmn:sequenceFlow id="SequenceFlow_5" sourceRef="Task_Enviar" targetRef="Task_Registrar" />
    <bpmn:sequenceFlow id="SequenceFlow_6" sourceRef="Task_Registrar" targetRef="EndEvent_Fim" />
  </bpmn:process>

  <bpmn:process id="Process_Prefeitura" name="Tramitação Externa" isExecutable="false">
    <bpmn:task id="Task_ReceberEdital" name="Receber Edital">
      <bpmn:outgoing>SequenceFlow_P1</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_Completo" name="Edital está completo e correto?">
      <bpmn:incoming>SequenceFlow_P1</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_Sim</bpmn:outgoing>
      <bpmn:outgoing>SequenceFlow_Nao</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_ConduzirPregao" name="Conduzir Pregão Eletrônico">
      <bpmn:incoming>SequenceFlow_Sim</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_P2</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_Devolver" name="Devolver Edital para correção">
      <bpmn:incoming>SequenceFlow_Nao</bpmn:incoming>
      <bpmn:outgoing>MessageFlow_Devolucao</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_Pregao" name="Pregão em andamento">
      <bpmn:incoming>SequenceFlow_P2</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="SequenceFlow_P1" sourceRef="Task_ReceberEdital" targetRef="Gateway_Completo" />
    <bpmn:sequenceFlow id="SequenceFlow_Sim" name="Sim" sourceRef="Gateway_Completo" targetRef="Task_ConduzirPregao" />
    <bpmn:sequenceFlow id="SequenceFlow_Nao" name="Não" sourceRef="Gateway_Completo" targetRef="Task_Devolver" />
    <bpmn:sequenceFlow id="SequenceFlow_P2" sourceRef="Task_ConduzirPregao" targetRef="EndEvent_Pregao" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_G06">

      <bpmndi:BPMNShape id="Shape_Participant_G06" bpmnElement="Participant_G06" isHorizontal="true">
        <dc:Bounds x="80" y="60" width="1180" height="420" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Participant_Prefeitura" bpmnElement="Participant_Prefeitura" isHorizontal="true">
        <dc:Bounds x="80" y="500" width="1180" height="260" />
      </bpmndi:BPMNShape>

      <!-- G06 elements -->
      <bpmndi:BPMNShape id="Shape_Start" bpmnElement="StartEvent_Inicio">
        <dc:Bounds x="120" y="182" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Receber" bpmnElement="Task_Receber">
        <dc:Bounds x="200" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Formatar" bpmnElement="Task_Formatar">
        <dc:Bounds x="350" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Anexar" bpmnElement="Task_Anexar">
        <dc:Bounds x="500" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Gateway_Validar" bpmnElement="Gateway_Validar" isMarkerVisible="true">
        <dc:Bounds x="650" y="175" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Enviar" bpmnElement="Task_Enviar">
        <dc:Bounds x="750" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Registrar" bpmnElement="Task_Registrar">
        <dc:Bounds x="900" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_End" bpmnElement="EndEvent_Fim">
        <dc:Bounds x="1050" y="182" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Corrigir" bpmnElement="Task_Corrigir">
        <dc:Bounds x="500" y="300" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- Prefeitura elements -->
      <bpmndi:BPMNShape id="Shape_ReceberEdital" bpmnElement="Task_ReceberEdital">
        <dc:Bounds x="750" y="520" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Gateway_Completo" bpmnElement="Gateway_Completo" isMarkerVisible="true">
        <dc:Bounds x="900" y="535" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_ConduzirPregao" bpmnElement="Task_ConduzirPregao">
        <dc:Bounds x="1050" y="520" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_EndPregao" bpmnElement="EndEvent_Pregao">
        <dc:Bounds x="1200" y="542" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Devolver" bpmnElement="Task_Devolver">
        <dc:Bounds x="900" y="650" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- Sequence flows G06 -->
      <bpmndi:BPMNEdge id="Edge_1" bpmnElement="SequenceFlow_1">
        <di:waypoint x="156" y="200" />
        <di:waypoint x="200" y="200" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_2" bpmnElement="SequenceFlow_2">
        <di:waypoint x="300" y="200" />
        <di:waypoint x="350" y="200" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_3" bpmnElement="SequenceFlow_3">
        <di:waypoint x="450" y="200" />
        <di:waypoint x="500" y="200" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_4" bpmnElement="SequenceFlow_4">
        <di:waypoint x="600" y="200" />
        <di:waypoint x="650" y="200" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Completo" bpmnElement="SequenceFlow_Completo">
        <di:waypoint x="700" y="200" />
        <di:waypoint x="750" y="200" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="710" y="178" width="50" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Pendente" bpmnElement="SequenceFlow_Pendente">
        <di:waypoint x="675" y="225" />
        <di:waypoint x="675" y="340" />
        <di:waypoint x="600" y="340" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="680" y="270" width="90" height="28" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Loop" bpmnElement="SequenceFlow_Loop">
        <di:waypoint x="500" y="340" />
        <di:waypoint x="400" y="340" />
        <di:waypoint x="400" y="240" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_5" bpmnElement="SequenceFlow_5">
        <di:waypoint x="850" y="200" />
        <di:waypoint x="900" y="200" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_6" bpmnElement="SequenceFlow_6">
        <di:waypoint x="1000" y="200" />
        <di:waypoint x="1050" y="200" />
      </bpmndi:BPMNEdge>

      <!-- Sequence flows Prefeitura -->
      <bpmndi:BPMNEdge id="Edge_P1" bpmnElement="SequenceFlow_P1">
        <di:waypoint x="850" y="560" />
        <di:waypoint x="900" y="560" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Sim" bpmnElement="SequenceFlow_Sim">
        <di:waypoint x="950" y="560" />
        <di:waypoint x="1050" y="560" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="985" y="538" width="30" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Nao" bpmnElement="SequenceFlow_Nao">
        <di:waypoint x="925" y="585" />
        <di:waypoint x="925" y="650" />
        <di:waypoint x="950" y="650" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="930" y="610" width="30" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_P2" bpmnElement="SequenceFlow_P2">
        <di:waypoint x="1150" y="560" />
        <di:waypoint x="1200" y="560" />
      </bpmndi:BPMNEdge>

      <!-- Message flows -->
      <bpmndi:BPMNEdge id="Edge_MF_Envio" bpmnElement="MessageFlow_Envio">
        <di:waypoint x="800" y="240" />
        <di:waypoint x="800" y="520" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="805" y="370" width="80" height="28" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_MF_Devolucao" bpmnElement="MessageFlow_Devolucao">
        <di:waypoint x="900" y="690" />
        <di:waypoint x="550" y="690" />
        <di:waypoint x="550" y="380" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="555" y="530" width="80" height="28" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
